# Server
NODE_ENV=development
PORT=3000

# Database (use either DATABASE_URL or individual params)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=promo_admin
DB_USER=promo_admin
DB_PASSWORD=dev_password_123

# Redis (use either REDIS_URL or individual params)
# REDIS_URL=redis://host:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT & Cookie signing — use a long random value in production (>= 32 chars each)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=8h
COOKIE_SECRET=your-super-secret-cookie-signing-key-change-in-production

# Allowed CORS origins (comma-separated, no trailing slashes)
ALLOWED_ORIGINS=http://localhost:5173

# Email (configure with your SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@kitkat-promo.com

# Region for multi-host: az (Azerbaijan), ge (Georgia), am (Armenia)
# REGION=az

# SMS provider: ge_sms (default) | az_sms | am_sms | mock
SMS_PROVIDER=ge_sms
GE_SMS_API_KEY=your_sender_ge_api_key

# Azerbaijan (LSIM)
# AZ_SMS_LOGIN=
# AZ_SMS_API_KEY=    # LSIM password
# AZ_SMS_SENDER=
# AZ_SMS_API_URL=https://apps.lsim.az/quicksms/v1

# Georgia (sender.ge)
# GE_SMS_API_KEY=
# GE_SMS_API_URL=https://sender.ge/api

# Armenia (MOBIPACE)
# AM_SMS_USERNAME=
# AM_SMS_API_KEY=    # MOBIPACE password
# AM_SMS_SENDER=
# AM_SMS_API_URL=https://endpoint.mobipace.com:444

# OTP Settings
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
